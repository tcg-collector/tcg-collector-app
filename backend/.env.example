# Copiar este arquivo para .env e preencher os valores
# NUNCA commitar o arquivo .env

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<usuario>:<senha>@cluster0.xxxxx.mongodb.net/tcg-collector

# PokéTCG API (obter em: https://pokemontcg.io)
POKEMONTCG_API_KEY=seu_api_key_aqui

# ExchangeRate API (obter em: https://exchangerate-api.com)
EXCHANGE_RATE_API_KEY=seu_api_key_aqui

# Autenticação JWT
JWT_SECRET=gerar_uma_string_longa_e_aleatoria_aqui
JWT_EXPIRES_IN=7d

# Servidor
PORT=3000
NODE_ENV=development
